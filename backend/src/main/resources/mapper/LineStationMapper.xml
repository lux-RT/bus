<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.bus.mapper.LineStationMapper">

    <resultMap id="lineStationResultMap" type="com.bus.entity.LineStation">
        <result property="lineId" column="line_id"/>
        <result property="stationId" column="station_id"/>
        <result property="sequence" column="sequence"/>
    </resultMap>

    <select id="selectByLineId" resultMap="lineStationResultMap">
        SELECT line_id, station_id, sequence
        FROM line_station
        WHERE line_id = #{lineId}
        ORDER BY sequence
    </select>

    <insert id="insert">
        INSERT INTO line_station (line_id, station_id, sequence)
        VALUES (#{lineId}, #{stationId}, #{sequence})
    </insert>

    <delete id="deleteByLineAndStation">
        DELETE FROM line_station
        WHERE line_id = #{lineId} AND station_id = #{stationId}
    </delete>

    <delete id="deleteByLineId">
        DELETE FROM line_station
        WHERE line_id = #{lineId}
    </delete>

</mapper>
